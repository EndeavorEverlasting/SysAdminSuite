{
  "schema_version": "sas-package-static-analysis-skill/v1",
  "skill_path": ".claude/skills/package-static-analysis/SKILL.md",
  "result_schema": "schemas/harness/package-static-analysis-result.schema.json",
  "operation": {
    "id": "package_analysis.static",
    "summary": "Analyze local executable, MSI, archive, script, and configuration packages without executing package code.",
    "mode": "local_read",
    "network_activity": false,
    "target_mutation": false,
    "package_execution": false,
    "archive_payload_extraction": false,
    "inputs": [
      "operator_local_file_or_directory",
      "optional_offline_wheelhouse",
      "bounded_analysis_limits"
    ],
    "outputs": [
      "package_analysis.json",
      "package_analysis.txt"
    ],
    "guardrails": [
      "explicit_local_input_required",
      "no_shortcut_following",
      "no_archive_payload_extraction",
      "no_process_or_installer_execution",
      "no_network_activity",
      "no_target_or_host_mutation",
      "raw_strings_not_emitted",
      "endpoints_fingerprinted_not_logged",
      "signature_table_presence_is_not_trust_validation",
      "runtime_behavior_requires_separate_vm_lane"
    ]
  }
}
