{
  "schema_version": "sas-harness-api/v1",
  "posture": {
    "default_network_activity": false,
    "default_target_mutation": false,
    "evidence_scope": "local_gitignored_artifacts",
    "operator_boundary": "authorized_scoped_low_noise_no_hidden_activity",
    "approved_software_sources": [
      "\\\\nt2kwb972sms01\\"
    ]
  },
  "modes": [
    "plan_only",
    "local_read",
    "local_transform",
    "operator_execute"
  ],
  "operations": [
    {
      "id": "target_reduction.plan",
      "summary": "Classify prior probe results into reduced targets, retry candidates, review rows, and location/subnet candidates.",
      "mode": "local_transform",
      "network_activity": false,
      "target_mutation": false,
      "inputs": [
        "prior_probe_results_csv",
        "optional_location_subnet_map_csv",
        "optional_identity_evidence_csv"
      ],
      "outputs": [
        "reduced_targets.csv",
        "retry_candidates.csv",
        "review_required.csv",
        "location_subnet_candidates.csv",
        "target_reduction_summary.json"
      ],
      "guardrails": [
        "NoPing_NoTcp_DNS_failure_is_not_dead",
        "Reachability_is_not_serial_proof",
        "Candidate_discovery_is_not_identity_proof",
        "Do_not_probe_from_this_operation"
      ]
    },
    {
      "id": "standard_probe.render_cmd",
      "summary": "Render CMD commands for approved single-target checks without executing them.",
      "mode": "plan_only",
      "network_activity": false,
      "target_mutation": false,
      "inputs": [
        "approved_hostname_or_ip",
        "optional_port"
      ],
      "outputs": [
        "cmd_command_plan.txt"
      ],
      "guardrails": [
        "Render_only",
        "No_blind_subnet_sweeps",
        "One_target_unless_manifest_approved"
      ]
    },
    {
      "id": "standard_probe.render_powershell",
      "summary": "Render PowerShell commands for approved single-target checks without executing them.",
      "mode": "plan_only",
      "network_activity": false,
      "target_mutation": false,
      "inputs": [
        "approved_hostname_or_ip",
        "optional_port"
      ],
      "outputs": [
        "powershell_command_plan.ps1"
      ],
      "guardrails": [
        "Render_only",
        "Use_short_targeted_checks",
        "No_target_mutation"
      ]
    },
    {
      "id": "report.generate_from_artifacts",
      "summary": "Generate local reports from approved local artifacts with input/output provenance.",
      "mode": "local_transform",
      "network_activity": false,
      "target_mutation": false,
      "inputs": [
        "artifact_manifest_json",
        "summary_json",
        "csv_artifacts"
      ],
      "outputs": [
        "report.md",
        "report_summary.json"
      ],
      "guardrails": [
        "Reports_must_name_inputs",
        "Reports_must_name_unresolved_rows",
        "Reports_must_not_invent_identity_proof"
      ]
    },
    {
      "id": "mcp.catalog.list",
      "summary": "List local MCP servers and their permitted harness APIs.",
      "mode": "local_read",
      "network_activity": false,
      "target_mutation": false,
      "inputs": [
        "mcp/local/servers.json"
      ],
      "outputs": [
        "mcp_server_catalog.json"
      ],
      "guardrails": [
        "Local_only",
        "No_hidden_daemons",
        "No_network_probe_execution"
      ]
    },
    {
      "id": "software_install.operator_execute",
      "summary": "Install approved software on authorized target computers from approved read-only software shares with local evidence and target staging cleanup.",
      "mode": "operator_execute",
      "network_activity": true,
      "target_mutation": true,
      "inputs": [
        "approved_targets_csv_or_computer_name",
        "package_name",
        "installer_relative_path",
        "software_share_root",
        "installer_arguments",
        "explicit_allow_target_mutation"
      ],
      "outputs": [
        "software_install_events.jsonl",
        "software_install_summary.json",
        "operator_handoff.txt"
      ],
      "guardrails": [
        "Approved_admin_context_only",
        "Approved_read_only_software_share_only",
        "No_credential_collection",
        "No_monitoring_bypass_or_log_suppression",
        "No_unapproved_background_services",
        "Prefer_UNC_direct_install_to_avoid_target_staging",
        "Temporary_staging_must_be_removed_and_cleanup_status_reported",
        "Local_gitignored_evidence_only"
      ]
    }
  ]
}
