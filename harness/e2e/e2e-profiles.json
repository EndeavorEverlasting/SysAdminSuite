{
  "schema_version": "sas-e2e-profiles/v1",
  "schema_path": "schemas/harness/e2e-validation-profiles.schema.json",
  "default_profile": "default",
  "posture": {
    "end_to_end_default_required": true,
    "unit_tests_sufficient_for_merge": false,
    "external_network_activity_default": false,
    "target_mutation_default": false,
    "tracked_runtime_evidence_allowed": false
  },
  "journeys": [
    {
      "id": "harness-one-command-synthetic",
      "summary": "Run the real one-command harness through run context, artifact registration, report rendering, contracts, and final result emission.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/validate-sysadmin-harness.ps1",
      "arguments": ["-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "software-install-fixture",
      "summary": "Run the real software-install operator wrapper and generated installer executable against an isolated fixture target, then prove package-state deltas and structured evidence.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasSoftwareInstallE2E.ps1",
      "arguments": ["-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "software-install-validated-finalization",
      "summary": "Run the real validated-deployment orchestrator with a generated installer in CopyThenInstall mode, validate the package, remove an injected run-scoped transient, and prove the package remains.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasValidatedSoftwareDeploymentE2E.ps1",
      "arguments": ["-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "software-install-result-presentation",
      "summary": "Inspect the validated deployment evidence, recompute install, validation, teardown, remnant, and preservation counts, and present the final deployment classification.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Show-SasValidatedSoftwareDeploymentResult.ps1",
      "arguments": [
        "-OutputRoot",
        "{run_root}\\software-install-validated-finalization\\operator",
        "-RequireCompleted"
      ],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "dashboard-relay-cancel-loopback",
      "summary": "Start the real dashboard relay and prove authenticated loopback cancellation preserves partial evidence and stops later targets.",
      "runtime_candidates": ["python", "python3"],
      "script": "dashboard/test_relay_cancel_e2e.py",
      "arguments": [],
      "network_scope": "loopback-only",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "dashboard-relay-abort-loopback",
      "summary": "Drive the real relay client against the real relay and prove process death becomes an aborted partial-result classification.",
      "runtime_candidates": ["node"],
      "script": "dashboard/test_relay_abort_e2e.js",
      "arguments": [],
      "network_scope": "loopback-only",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-windows-native-success",
      "summary": "Prove Windows native workstation success path including planning, apply to disposable HOME, and rollback.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-windows-native-success", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-linux-native-success",
      "summary": "Prove Linux native workstation success path or syntax validation.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-linux-native-success", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-wsl-opt-in",
      "summary": "Prove WSL opt-in terminal profile generation behavior.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-wsl-opt-in", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-missing-wezterm",
      "summary": "Prove graceful planning when WezTerm is absent.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-missing-wezterm", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-missing-shell",
      "summary": "Prove default fallback shell selection when preferred shell is absent.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-missing-shell", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-missing-tmux-linux",
      "summary": "Prove skip behavior when tmux is missing on Linux.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-missing-tmux-linux", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-auth-required",
      "summary": "Prove warning/skip behavior when Switchboard requires authentication.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-auth-required", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-malformed-switchboard",
      "summary": "Prove planning does not crash on malformed agent switchboard inventory.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-malformed-switchboard", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-unsupported-version",
      "summary": "Prove warning/rejection on unsupported contract version.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-unsupported-version", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-config-conflict",
      "summary": "Prove update/replacement logic when config managed block exists.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-config-conflict", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-rollback-on-failure",
      "summary": "Prove rollback after apply failure restores base config state.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-rollback-on-failure", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    },
    {
      "id": "workstation-unsupported-macos",
      "summary": "Prove graceful SKIP behavior when running on unsupported macOS platform.",
      "runtime_candidates": ["pwsh", "powershell.exe", "powershell"],
      "script": "scripts/Invoke-SasWorkstationE2E.ps1",
      "arguments": ["-JourneyId", "workstation-unsupported-macos", "-OutputRoot", "{journey_output}"],
      "network_scope": "none",
      "target_mutation": false,
      "required": true
    }
  ],
  "profiles": [
    {
      "id": "default",
      "proof_class": "fixture-loopback-e2e",
      "journey_ids": [
        "harness-one-command-synthetic",
        "software-install-fixture",
        "software-install-validated-finalization",
        "software-install-result-presentation",
        "dashboard-relay-cancel-loopback",
        "dashboard-relay-abort-loopback"
      ]
    },
    {
      "id": "developer-workstation-bimodal-e2e",
      "proof_class": "fixture-loopback-e2e",
      "journey_ids": [
        "workstation-windows-native-success",
        "workstation-linux-native-success",
        "workstation-wsl-opt-in",
        "workstation-missing-wezterm",
        "workstation-missing-shell",
        "workstation-missing-tmux-linux",
        "workstation-auth-required",
        "workstation-malformed-switchboard",
        "workstation-unsupported-version",
        "workstation-config-conflict",
        "workstation-rollback-on-failure",
        "workstation-unsupported-macos"
      ]
    }
  ]
}
