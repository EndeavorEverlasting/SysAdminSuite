#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
remote_name="${1:-origin}"
cd "$repo_root"

echo "[sas-harness] pre-push: running offline survey guardrails"
bash tests/survey/run_offline_survey_tests.sh
python3 Tests/survey/test_operational_harness_completeness_contracts.py
python3 Tests/survey/test_local_harness_contracts.py
python3 Tests/survey/test_sprint_working_rules_contracts.py

checked_commit=0
saw_ref_update=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -n "${local_sha:-}" ]] || continue
  saw_ref_update=1

  # A zero local SHA deletes the destination ref and carries no new commit content.
  [[ "$local_sha" =~ ^0+$ ]] && continue

  if [[ "$remote_sha" =~ ^0+$ ]]; then
    # New destination ref: validate commits not already present on this destination remote.
    mapfile -t destination_refs < <(
      git for-each-ref --format='%(refname)' "refs/remotes/${remote_name}/"
    )
    if [[ "${#destination_refs[@]}" -gt 0 ]]; then
      rev_list=("$local_sha" --not "${destination_refs[@]}")
    else
      rev_list=("$local_sha")
    fi
  else
    # Existing destination ref: validate exactly the commits the push adds there.
    rev_list=("${remote_sha}..${local_sha}")
  fi

  while read -r commit; do
    [[ -n "$commit" ]] || continue
    python3 scripts/check-repo-text-policy.py --commit "$commit"
    checked_commit=1
  done < <(git rev-list "${rev_list[@]}")
done

# Manual hook invocation has no ref-update input; validate the current commit.
if [[ "$saw_ref_update" -eq 0 && "$checked_commit" -eq 0 ]]; then
  python3 scripts/check-repo-text-policy.py --commit HEAD
fi

echo "[sas-harness] pre-push: ok"
