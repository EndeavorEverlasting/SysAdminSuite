{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/harness/developer-workstation-orchestrator-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "mode", "platform", "execution_domain", "outcome", "steps", "artifacts", "proof"],
  "properties": {
    "schema_version": {"const": "sas-developer-workstation-orchestrator-result/v2"},
    "run_id": {"type":"string","pattern":"^developer-workstation-[0-9]{8}-[0-9]{6}-[a-f0-9]{8}$"},
    "mode": {"enum": ["Inventory", "Plan", "Apply", "Start", "Status", "Stop", "Repair", "Validate", "Rollback"]},
    "platform": {"enum": ["windows", "linux", "macos"]},
    "execution_domain": {"enum": ["windows-native", "windows-wsl", "linux-native", "unsupported"]},
    "outcome": {"enum": ["PASS", "PARTIAL", "FAIL", "ACTION_REQUIRED", "UNSUPPORTED"]},
    "steps": {"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["name","status","message"],"properties":{"name":{"type":"string","minLength":1},"status":{"enum":["PASS","SKIP","FAIL","ACTION_REQUIRED"]},"message":{"type":"string","minLength":1},"artifact_role":{"enum":["inventory","plan","backend-status","agentswitchboard-result","rollback-result"]}}}},
    "artifacts": {"type":"array","items":{"type":"object","additionalProperties":false,"required":["role","path"],"properties":{"role":{"enum":["inventory","plan","backend-status","agentswitchboard-result","rollback-result","english-summary"]},"path":{"type":"string","pattern":"^(?![A-Za-z]:)(?!/)(?!.*\\.\\.).+$"}}}},
    "proof": {"type":"object","additionalProperties":false,"required":["fixture","live_runtime","behavior_observed","persistence_observed","operator_accepted"],"properties":{"fixture":{"type":"boolean"},"live_runtime":{"const":false},"behavior_observed":{"const":false},"persistence_observed":{"const":false},"operator_accepted":{"const":false}}}
  }
}
