{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/harness/autologon-proof-receipt.schema.json",
  "title": "SysAdminSuite public-safe AutoLogon proof receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_evidence_sha256",
    "source_evidence_size_bytes",
    "classification",
    "proof_level",
    "reason_codes",
    "operator_confirmed",
    "privacy_status"
  ],
  "properties": {
    "schema_version": { "const": "sas-autologon-proof-receipt/v1" },
    "source_evidence_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_evidence_size_bytes": { "type": "integer", "minimum": 2 },
    "classification": { "enum": ["contract_only", "acceptance_proven", "acceptance_failed", "blocked"] },
    "proof_level": { "enum": ["sanitized_fixture_contract", "deployment_execution", "operator_accepted_runtime", "insufficient"] },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,95}$" }
    },
    "operator_confirmed": { "type": "boolean" },
    "privacy_status": { "const": "public_safe_source_hashed_not_copied" }
  },
  "allOf": [
    {
      "if": { "properties": { "classification": { "const": "contract_only" } }, "required": ["classification"] },
      "then": {
        "properties": {
          "proof_level": { "const": "sanitized_fixture_contract" },
          "operator_confirmed": { "const": false }
        }
      }
    },
    {
      "if": { "properties": { "classification": { "const": "acceptance_proven" } }, "required": ["classification"] },
      "then": {
        "properties": {
          "proof_level": { "const": "operator_accepted_runtime" },
          "operator_confirmed": { "const": true }
        }
      }
    }
  ]
}
