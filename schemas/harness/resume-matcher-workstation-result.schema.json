{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/SysAdminSuite/schemas/harness/resume-matcher-workstation-result.schema.json",
  "title": "SysAdminSuite Resume Matcher workstation result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "operation",
    "outcome",
    "lifecycle_state",
    "reason_codes",
    "message",
    "configuration",
    "inventory",
    "acceptance",
    "proof"
  ],
  "properties": {
    "schema_version": { "const": "sas-resume-matcher-workstation-result/v1" },
    "workflow_id": { "const": "resume-matcher-workstation" },
    "operation": { "enum": ["plan", "apply", "start", "status", "stop", "validate", "accept"] },
    "outcome": { "enum": ["success", "action-required", "failure"] },
    "lifecycle_state": { "enum": ["absent", "planned", "configured", "installed", "ready", "running", "accepted", "stopped", "degraded"] },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9-]+$" }
    },
    "message": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "application_root", "api_key_automated", "fixture_mode", "provider_health_required"],
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "application_root": { "type": "string", "minLength": 1 },
        "api_key_automated": { "const": false },
        "fixture_mode": { "type": "boolean" },
        "provider_health_required": { "type": "boolean" }
      }
    },
    "inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_present",
        "repo_dirty",
        "uv_available",
        "node_available",
        "python_ready",
        "browser_ready",
        "tmux_available",
        "backend_healthy",
        "frontend_healthy"
      ],
      "properties": {
        "repo_present": { "type": "boolean" },
        "repo_dirty": { "type": "boolean" },
        "uv_available": { "type": "boolean" },
        "node_available": { "type": "boolean" },
        "python_ready": { "type": "boolean" },
        "browser_ready": { "type": "boolean" },
        "tmux_available": { "type": "boolean" },
        "backend_healthy": { "type": "boolean" },
        "frontend_healthy": { "type": "boolean" }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_reused",
        "frontend_content_observed",
        "browser_launch_observed",
        "pdf_export_observed",
        "provider_configured",
        "provider_health_observed",
        "provider",
        "model",
        "pdf_artifact_path",
        "pdf_sha256",
        "pdf_size_bytes",
        "acceptance_completed"
      ],
      "properties": {
        "runtime_reused": { "type": "boolean" },
        "frontend_content_observed": { "type": "boolean" },
        "browser_launch_observed": { "type": "boolean" },
        "pdf_export_observed": { "type": "boolean" },
        "provider_configured": { "type": "boolean" },
        "provider_health_observed": { "type": "boolean" },
        "provider": { "type": ["string", "null"], "maxLength": 128 },
        "model": { "type": ["string", "null"], "maxLength": 256 },
        "pdf_artifact_path": { "type": ["string", "null"], "maxLength": 2048 },
        "pdf_sha256": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            { "type": "null" }
          ]
        },
        "pdf_size_bytes": { "type": "integer", "minimum": 0 },
        "acceptance_completed": { "type": "boolean" }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "install_completed",
        "configuration_applied",
        "launcher_started",
        "backend_health_observed",
        "frontend_health_observed",
        "browser_launch_observed",
        "pdf_export_observed",
        "provider_health_observed",
        "live_runtime",
        "acceptance_completed"
      ],
      "properties": {
        "install_completed": { "type": "boolean" },
        "configuration_applied": { "type": "boolean" },
        "launcher_started": { "type": "boolean" },
        "backend_health_observed": { "type": "boolean" },
        "frontend_health_observed": { "type": "boolean" },
        "browser_launch_observed": { "type": "boolean" },
        "pdf_export_observed": { "type": "boolean" },
        "provider_health_observed": { "type": "boolean" },
        "live_runtime": { "type": "boolean" },
        "acceptance_completed": { "type": "boolean" }
      }
    }
  }
}
