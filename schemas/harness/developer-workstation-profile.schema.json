{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/harness/developer-workstation-profile.schema.json",
  "title": "SysAdminSuite Developer Workstation Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "workspace",
    "platform_support",
    "terminal",
    "agent_switchboard",
    "posture"
  ],
  "properties": {
    "schema_version": {
      "const": "sas-developer-workstation-profile/v2"
    },
    "schema_path": {
      "const": "schemas/harness/developer-workstation-profile.schema.json"
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "repo_path"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "repo_path": {
          "$ref": "#/$defs/portablePath"
        }
      }
    },
    "platform_support": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported",
        "unsupported",
        "runtime_test_available"
      ],
      "properties": {
        "supported": {
          "const": [
            "windows",
            "linux"
          ]
        },
        "unsupported": {
          "const": [
            "macos"
          ]
        },
        "runtime_test_available": {
          "const": {
            "windows": true,
            "linux": true,
            "macos": false
          }
        }
      }
    },
    "terminal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "preference",
        "default_profiles",
        "execution_profiles"
      ],
      "properties": {
        "provider": {
          "const": "wezterm"
        },
        "preference": {
          "const": "required"
        },
        "default_profiles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "windows",
            "linux"
          ],
          "properties": {
            "windows": {
              "const": "windows-native"
            },
            "linux": {
              "const": "linux-native"
            }
          }
        },
        "execution_profiles": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/executionProfile"
          }
        }
      }
    },
    "agent_switchboard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "profile",
        "required_agents",
        "invocation_mode"
      ],
      "properties": {
        "repository": {
          "const": "EndeavorEverlasting/AgentSwitchboard"
        },
        "profile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "required_agents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "invocation_mode": {
          "const": "external-versioned-contract"
        }
      }
    },
    "posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "install_missing_only",
        "preserve_existing_configuration",
        "automatic_authentication",
        "target_mutation",
        "tracked_runtime_evidence"
      ],
      "properties": {
        "install_missing_only": {
          "const": true
        },
        "preserve_existing_configuration": {
          "const": true
        },
        "automatic_authentication": {
          "const": false
        },
        "target_mutation": {
          "const": false
        },
        "tracked_runtime_evidence": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
    },
    "executionProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "platform",
        "environment",
        "priority",
        "enabled",
        "shell",
        "multiplexer"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "platform": {
          "enum": [
            "windows",
            "linux"
          ]
        },
        "environment": {
          "enum": [
            "native",
            "wsl"
          ]
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "enabled": {
          "type": "boolean"
        },
        "shell": {
          "enum": [
            "pwsh",
            "powershell",
            "cmd",
            "bash",
            "zsh"
          ]
        },
        "multiplexer": {
          "enum": [
            "none",
            "tmux"
          ]
        },
        "distribution": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "environment": {
                "const": "wsl"
              }
            },
            "required": [
              "environment"
            ]
          },
          "then": {
            "required": [
              "distribution"
            ],
            "properties": {
              "platform": {
                "const": "windows"
              }
            }
          },
          "else": {
            "not": {
              "required": [
                "distribution"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "platform": {
                "const": "linux"
              }
            },
            "required": [
              "platform"
            ]
          },
          "then": {
            "properties": {
              "environment": {
                "const": "native"
              },
              "shell": {
                "enum": [
                  "bash",
                  "zsh"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "platform": {
                "const": "windows"
              },
              "environment": {
                "const": "native"
              }
            },
            "required": [
              "platform",
              "environment"
            ]
          },
          "then": {
            "properties": {
              "shell": {
                "enum": [
                  "pwsh",
                  "powershell",
                  "cmd"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
