{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/harness/developer-workstation-agent-routing.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "schema_path", "skill_id", "terminal_context_labels", "triggers", "guards"],
  "properties": {
    "schema_version": {"const": "sas-developer-workstation-agent-routing/v1"},
    "schema_path": {"const": "schemas/harness/developer-workstation-agent-routing.schema.json"},
    "skill_id": {"const": "developer-workstation"},
    "terminal_context_labels": {
      "const": ["Windows PowerShell", "WezTerm/tmux Bash", "file content: Lua"]
    },
    "triggers": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phrase", "operation", "capability_id", "terminal_context"],
        "properties": {
          "phrase": {"type": "string", "minLength": 4},
          "operation": {"enum": ["Plan", "Start", "Status", "Stop", "Repair", "AgentReadiness"]},
          "capability_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "terminal_context": {"enum": ["Windows PowerShell", "WezTerm/tmux Bash", "file content: Lua"]}
        }
      }
    },
    "guards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["already_inside_tmux", "lua_content", "default_mutation", "automatic_authentication", "inject_user_home_content", "mac_supported"],
      "properties": {
        "already_inside_tmux": {"const": "route-to-status-or-current-session"},
        "lua_content": {"const": "route-to-managed-file-operation"},
        "default_mutation": {"const": false},
        "automatic_authentication": {"const": false},
        "inject_user_home_content": {"const": false},
        "mac_supported": {"const": false}
      }
    }
  }
}
