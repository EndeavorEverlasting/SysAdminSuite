{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/harness/validated-software-deployment-request.schema.json",
  "title": "SysAdminSuite Validated Software Deployment Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "package_name",
    "software_share_root",
    "installer_relative_path",
    "installer_sha256",
    "installer_arguments",
    "installer_arguments_reference",
    "install_mode",
    "targets",
    "authorization",
    "validation",
    "cleanup_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "sas-validated-software-deployment-request/v1"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,96}$"
    },
    "package_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "software_share_root": {
      "type": "string",
      "pattern": "^\\\\\\\\[^\\\\]+\\\\?$"
    },
    "installer_relative_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "not": {
        "pattern": "(^|\\\\)\\.\\.(\\\\|$)"
      }
    },
    "installer_sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "installer_arguments": {
      "type": "array",
      "minItems": 0,
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      }
    },
    "installer_arguments_policy": {
      "enum": [
        "approved_empty"
      ]
    },
    "installer_arguments_reference": {
      "type": "string",
      "minLength": 3,
      "maxLength": 512
    },
    "install_mode": {
      "enum": [
        "UncDirect",
        "CopyThenInstall"
      ]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 25,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,252}$"
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorized_by",
        "request_reference",
        "change_reference",
        "ticket_reference"
      ],
      "properties": {
        "authorized_by": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        },
        "request_reference": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        },
        "change_reference": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        },
        "ticket_reference": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checks"
      ],
      "properties": {
        "checks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/check"
          }
        }
      }
    },
    "cleanup_policy": {
      "const": "repo_owned_run_scoped_only"
    },
    "require_valid_signature": {
      "type": "boolean",
      "default": false
    },
    "expected_signer_thumbprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40,64}$"
    }
  },
  "$defs": {
    "baseCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{1,63}$"
        },
        "type": {
          "enum": [
            "FileExists",
            "FileSha256Equals",
            "FileVersionEquals",
            "JsonPropertyEquals",
            "RegistryValueEquals",
            "UninstallEntry",
            "ServiceExists"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "path": {
          "type": "string",
          "minLength": 3,
          "maxLength": 1024
        },
        "expected_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "expected_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "property_path": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+(\\.[A-Za-z0-9_-]+)*$"
        },
        "expected_value": {
          "type": [
            "string",
            "number",
            "integer",
            "boolean"
          ]
        },
        "registry_path": {
          "type": "string",
          "pattern": "^HKLM:\\\\[^*?]+$"
        },
        "value_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 260
        },
        "service_name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]{1,256}$"
        },
        "expected_status": {
          "enum": [
            "Running",
            "Stopped",
            "Paused"
          ]
        }
      }
    },
    "check": {
      "allOf": [
        {
          "$ref": "#/$defs/baseCheck"
        },
        {
          "oneOf": [
            {
              "properties": {
                "type": {
                  "const": "FileExists"
                }
              },
              "required": [
                "path"
              ]
            },
            {
              "properties": {
                "type": {
                  "const": "FileSha256Equals"
                }
              },
              "required": [
                "path",
                "expected_sha256"
              ]
            },
            {
              "properties": {
                "type": {
                  "const": "FileVersionEquals"
                }
              },
              "required": [
                "path",
                "expected_version"
              ]
            },
            {
              "properties": {
                "type": {
                  "const": "JsonPropertyEquals"
                }
              },
              "required": [
                "path",
                "property_path",
                "expected_value"
              ]
            },
            {
              "properties": {
                "type": {
                  "const": "RegistryValueEquals"
                }
              },
              "required": [
                "registry_path",
                "value_name",
                "expected_value"
              ]
            },
            {
              "properties": {
                "type": {
                  "const": "UninstallEntry"
                }
              },
              "required": [
                "display_name"
              ]
            },
            {
              "properties": {
                "type": {
                  "const": "ServiceExists"
                }
              },
              "required": [
                "service_name"
              ]
            }
          ]
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "require_valid_signature": {
            "const": true
          }
        },
        "required": [
          "require_valid_signature"
        ]
      },
      "then": {
        "required": [
          "expected_signer_thumbprint"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "installer_arguments": {
            "maxItems": 0
          }
        },
        "required": [
          "installer_arguments"
        ]
      },
      "then": {
        "required": [
          "installer_arguments_policy"
        ],
        "properties": {
          "installer_arguments_policy": {
            "const": "approved_empty"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "installer_arguments_policy"
        ]
      },
      "then": {
        "properties": {
          "installer_arguments": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
