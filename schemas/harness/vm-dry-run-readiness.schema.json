{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sysadminsuite.local/schemas/harness/vm-dry-run-readiness.schema.json",
  "title": "SysAdminSuite VM dry-run readiness profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "proof_class",
    "dry_run_journey_ids",
    "safety",
    "provider_detection",
    "runtime_entry_requirements",
    "required_evidence",
    "proof_ceiling"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "sas-vm-dry-run-readiness/v1"
    },
    "schema_path": {
      "type": "string",
      "const": "schemas/harness/vm-dry-run-readiness.schema.json"
    },
    "proof_class": {
      "type": "string",
      "const": "synthetic_offline_vm_readiness"
    },
    "dry_run_journey_ids": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "software-install-fixture",
          "software-install-validated-finalization",
          "software-install-result-presentation"
        ]
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readiness_validator_starts_vm",
        "readiness_validator_executes_real_package",
        "readiness_validator_mutates_host",
        "readiness_validator_contacts_target",
        "readiness_validator_uses_external_network",
        "autologon_allowed",
        "runtime_vm_must_be_disposable",
        "rollback_or_destroy_required",
        "one_package_per_clean_snapshot"
      ],
      "properties": {
        "readiness_validator_starts_vm": {"type": "boolean", "const": false},
        "readiness_validator_executes_real_package": {"type": "boolean", "const": false},
        "readiness_validator_mutates_host": {"type": "boolean", "const": false},
        "readiness_validator_contacts_target": {"type": "boolean", "const": false},
        "readiness_validator_uses_external_network": {"type": "boolean", "const": false},
        "autologon_allowed": {"type": "boolean", "const": false},
        "runtime_vm_must_be_disposable": {"type": "boolean", "const": true},
        "rollback_or_destroy_required": {"type": "boolean", "const": true},
        "one_package_per_clean_snapshot": {"type": "boolean", "const": true}
      }
    },
    "provider_detection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "required_for_offline_readiness", "commands"],
      "properties": {
        "mode": {
          "type": "string",
          "const": "command_presence_only"
        },
        "required_for_offline_readiness": {
          "type": "boolean",
          "const": false
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "vmconnect.exe",
              "WindowsSandbox.exe",
              "VBoxManage.exe",
              "vmrun.exe"
            ]
          }
        }
      }
    },
    "runtime_entry_requirements": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "provider_selected",
          "clean_checkpoint_or_ephemeral_guest",
          "host_negative_gate_passed",
          "approved_package_identity_available",
          "supported_installer_arguments_available",
          "guest_evidence_root_selected",
          "rollback_or_destroy_plan_recorded",
          "autologon_excluded"
        ]
      }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "host_preflight",
          "guest_baseline",
          "package_identity",
          "dry_run_plan",
          "install_result",
          "application_acceptance",
          "guest_delta",
          "rollback_or_destroy_result",
          "host_postflight"
        ]
      }
    },
    "proof_ceiling": {
      "type": "string",
      "const": "readiness_only_no_vm_started"
    }
  }
}
