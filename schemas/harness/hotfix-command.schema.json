{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sysadminsuite.local/schemas/harness/hotfix-command.schema.json",
  "title": "SysAdminSuite Hotfix Command Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command_id",
    "title",
    "status",
    "version",
    "risk_level",
    "requires_operator_confirmation",
    "intended_operator_position",
    "delivery_modes",
    "applies_to",
    "preconditions",
    "forbidden_use",
    "scan_instructions",
    "cmd_payload",
    "powershell_payload",
    "qr_payloads",
    "expected_result",
    "rollback_note",
    "evidence_to_capture"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "command_id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "approved-field-hotfix", "retired"] },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "requires_operator_confirmation": { "type": "boolean", "const": true },
    "intended_operator_position": { "type": "string", "enum": ["standing-at-target", "admin-reviewed-local-only"] },
    "delivery_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "admin-gui-qr-display",
          "suite-clone-local-qr-generation",
          "local-fileshare-staging",
          "public-release-fallback"
        ]
      }
    },
    "applies_to": { "$ref": "#/$defs/nonEmptyStringArray" },
    "preconditions": { "$ref": "#/$defs/nonEmptyStringArray" },
    "forbidden_use": { "$ref": "#/$defs/nonEmptyStringArray" },
    "scan_instructions": { "$ref": "#/$defs/nonEmptyStringArray" },
    "cmd_payload": { "type": "string", "minLength": 1, "maxLength": 200 },
    "powershell_payload": { "type": "string", "minLength": 1, "maxLength": 260 },
    "qr_payloads": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cmd_shift_f10", "powershell_console"],
      "properties": {
        "cmd_shift_f10": { "type": "string", "minLength": 1, "maxLength": 200 },
        "powershell_console": { "type": "string", "minLength": 1, "maxLength": 260 }
      }
    },
    "expected_result": { "type": "string", "minLength": 1 },
    "rollback_note": { "type": "string", "minLength": 1 },
    "evidence_to_capture": { "$ref": "#/$defs/nonEmptyStringArray" }
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
