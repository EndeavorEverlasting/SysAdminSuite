{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/harness/ai-provider-catalog.schema.json",
  "title": "SysAdminSuite AI Provider Catalog",
  "description": "Catalog of known AI model providers with free/paid tier classification, model listings, and fallback priority.",
  "type": "object",
  "required": [
    "schema_version",
    "catalog_policy",
    "tier_fallback_order",
    "provider_fallback_order",
    "providers"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": {
      "type": "string",
      "const": "sas-ai-provider-catalog/v1"
    },
    "catalog_policy": {
      "type": "object",
      "required": [
        "free_model_priority",
        "free_tokens_before_paid",
        "free_to_paid_fallback",
        "local_model_preference",
        "provider_authentication_never_automatic",
        "fallback_chain_logging_required"
      ],
      "properties": {
        "free_model_priority": { "type": "boolean", "const": true },
        "free_tokens_before_paid": { "type": "boolean", "const": true },
        "free_to_paid_fallback": { "type": "boolean", "const": true },
        "local_model_preference": { "type": "boolean", "const": true },
        "provider_authentication_never_automatic": { "type": "boolean", "const": true },
        "fallback_chain_logging_required": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "tier_fallback_order": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["free_local", "free_cloud_free_tokens", "free_cloud_trial", "paid"]
      },
      "minItems": 4,
      "maxItems": 4
    },
    "provider_fallback_order": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "display_name",
          "tier",
          "free_tokens_available",
          "runtime",
          "authentication_required",
          "notes",
          "models"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "tier": {
            "type": "string",
            "enum": ["free_local", "free_cloud_free_tokens", "free_cloud_trial", "paid"]
          },
          "free_tokens_available": { "type": "boolean" },
          "runtime": {
            "type": "string",
            "enum": ["local", "cloud"]
          },
          "authentication_required": { "type": "boolean" },
          "authentication_type": { "type": "string" },
          "notes": { "type": "string" },
          "setup_steps": {
            "type": "array",
            "items": { "type": "string" }
          },
          "models": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "display_name", "context_window"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "display_name": { "type": "string", "minLength": 1 },
                "provider": { "type": "string" },
                "context_window": { "type": "integer", "minimum": 1 },
                "coding_focus": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
