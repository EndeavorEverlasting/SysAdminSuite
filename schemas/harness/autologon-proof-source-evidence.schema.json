{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/harness/autologon-proof-source-evidence.schema.json",
  "title": "SysAdminSuite operator-local AutoLogon proof source evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_class",
    "classification",
    "reason_codes",
    "contract_fixture",
    "target_binding_sha256",
    "artifact_digests",
    "proof",
    "operator_confirmation",
    "privacy",
    "proof_level",
    "proof_ceiling"
  ],
  "properties": {
    "schema_version": { "const": "sas-autologon-proof-source-evidence/v1" },
    "evidence_class": { "enum": ["sanitized_fixture", "operator_local"] },
    "classification": {
      "enum": [
        "fixture_contract_only",
        "fixture_contract_failed",
        "deployment_proven_runtime_pending",
        "acceptance_proven",
        "acceptance_failed",
        "insufficient_evidence"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,95}$" }
    },
    "contract_fixture": { "type": "boolean" },
    "target_binding_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifact_digests": {
      "type": "array",
      "minItems": 5,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "sha256", "size_bytes"],
        "properties": {
          "role": {
            "enum": [
              "deployment_result",
              "final_step_gate_result",
              "state_proof_result",
              "session_access_proof",
              "technician_runtime_proof",
              "transport_receipt"
            ]
          },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 2 }
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "administrator_approved",
        "canonical_transport_used",
        "deployment_succeeded",
        "reboot_observed",
        "automatic_sign_in_observed",
        "expected_account_match",
        "session_access_proven",
        "application_behavior_proven",
        "cleanup_verified"
      ],
      "properties": {
        "administrator_approved": { "type": "boolean" },
        "canonical_transport_used": { "type": "boolean" },
        "deployment_succeeded": { "type": "boolean" },
        "reboot_observed": { "type": "boolean" },
        "automatic_sign_in_observed": { "type": "boolean" },
        "expected_account_match": { "type": "boolean" },
        "session_access_proven": { "type": "boolean" },
        "application_behavior_proven": { "type": "boolean" },
        "cleanup_verified": { "type": "boolean" }
      }
    },
    "operator_confirmation": { "type": "boolean" },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source_retained_operator_local",
        "source_copied_to_public_output",
        "default_password_value_present",
        "credentials_present"
      ],
      "properties": {
        "status": { "enum": ["operator_local_private", "sanitized_fixture"] },
        "source_retained_operator_local": { "const": true },
        "source_copied_to_public_output": { "const": false },
        "default_password_value_present": { "const": false },
        "credentials_present": { "const": false }
      }
    },
    "proof_level": { "enum": ["sanitized_fixture_contract", "deployment_execution", "operator_accepted_runtime", "insufficient"] },
    "proof_ceiling": { "type": "string", "minLength": 40, "maxLength": 1024 }
  },
  "allOf": [
    {
      "if": { "properties": { "contract_fixture": { "const": true } }, "required": ["contract_fixture"] },
      "then": {
        "properties": {
          "evidence_class": { "const": "sanitized_fixture" },
          "classification": { "enum": ["fixture_contract_only", "fixture_contract_failed"] },
          "operator_confirmation": { "const": false },
          "proof_level": { "const": "sanitized_fixture_contract" },
          "privacy": { "properties": { "status": { "const": "sanitized_fixture" } } },
          "proof": {
            "properties": {
              "canonical_transport_used": { "const": false },
              "deployment_succeeded": { "const": false },
              "reboot_observed": { "const": false },
              "automatic_sign_in_observed": { "const": false },
              "expected_account_match": { "const": false },
              "session_access_proven": { "const": false },
              "application_behavior_proven": { "const": false },
              "cleanup_verified": { "const": false }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "classification": { "const": "acceptance_proven" } }, "required": ["classification"] },
      "then": {
        "properties": {
          "evidence_class": { "const": "operator_local" },
          "contract_fixture": { "const": false },
          "operator_confirmation": { "const": true },
          "proof_level": { "const": "operator_accepted_runtime" },
          "privacy": { "properties": { "status": { "const": "operator_local_private" } } },
          "proof": {
            "properties": {
              "administrator_approved": { "const": true },
              "canonical_transport_used": { "const": true },
              "deployment_succeeded": { "const": true },
              "reboot_observed": { "const": true },
              "automatic_sign_in_observed": { "const": true },
              "expected_account_match": { "const": true },
              "session_access_proven": { "const": true },
              "application_behavior_proven": { "const": true },
              "cleanup_verified": { "const": true }
            }
          }
        }
      }
    }
  ]
}
