#!/bin/bash
# Automatically push to GitHub after every commit.
# Installed to .git/hooks/post-commit by scripts/post-merge.sh.

if [ -z "$GITHUB_TOKEN" ]; then
  echo "[github-sync] GITHUB_TOKEN not set — skipping GitHub push."
  exit 0
fi

git config --global credential.helper \
  '!f() { echo "username=x-token-auth"; echo "password='"$GITHUB_TOKEN"'"; }; f'

CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [ "$CURRENT_BRANCH" != "main" ]; then
  exit 0
fi

echo "[github-sync] Pushing main to GitHub..."
if git push origin main; then
  echo "[github-sync] Push succeeded."
else
  echo "[github-sync] Push failed (non-fast-forward?). GitHub may have diverged from Replit."
  exit 1
fi
