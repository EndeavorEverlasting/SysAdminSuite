    {
      "id": "ollama",
      "display_name": "Ollama Local",
      "tier": "free_local",
      "free_tokens_available": true,
      "runtime": "local",
      "authentication_required": false,
      "notes": "Local LLM runtime via Ollama. No API key, no token billing. Unlimited free inference on local hardware. Run `ollama pull <model>` to download models. Preferred fallback target when no cloud provider is reachable.",
      "setup_steps": [
        "Install Ollama from https://ollama.com",
        "ollama pull deepseek-coder-v2",
        "ollama pull llama3.1",
        "ollama pull phi4",
        "ollama pull mistral"
      ],
      "models": [
        {"id": "deepseek-coder-v2",   "display_name": "DeepSeek Coder V2",   "context_window": 128000, "coding_focus": true},
        {"id": "llama3.1",           "display_name": "Llama 3.1",            "context_window": 128000, "coding_focus": false},
        {"id": "phi4",               "display_name": "Phi-4",                "context_window": 128000, "coding_focus": true},
        {"id": "mistral",            "display_name": "Mistral",              "context_window": 32000,  "coding_focus": false},
