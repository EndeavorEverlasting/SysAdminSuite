{
  "$schema": "../schemas/harness/ai-provider-catalog.schema.json",
  "schema_version": "sas-ai-provider-catalog/v1",
  "catalog_policy": {
    "free_model_priority": true,
    "free_tokens_before_paid": true,
    "free_to_paid_fallback": true,
    "local_model_preference": true,
    "provider_authentication_never_automatic": true,
    "fallback_chain_logging_required": true,
    "agent_feedback_tracking_enabled": true,
    "feedback_gates_orchestrator_routing": true
  },
  "tier_fallback_order": [
    "free_local",
    "free_cloud_free_tokens",
    "free_cloud_trial",
    "paid"
  ],
  "provider_fallback_order": [
    "ollama",
    "github-models",
    "google-ai-studio",
    "groq",
    "huggingface-inference",
    "mistral",
    "deepseek",
    "cohere",
    "openai",
    "anthropic",
    "google-vertex",
    "amazon-bedrock"
  ],
