{
  "schema_version": "sas-developer-workstation-profile/v2",
  "schema_path": "schemas/harness/developer-workstation-profile.schema.json",
  "workspace": {
    "name": "SysAdminSuite",
    "repo_path": "projects/SysAdminSuite"
  },
  "platform_support": {
    "supported": [
      "windows",
      "linux"
    ],
    "unsupported": [
      "macos"
    ],
    "runtime_test_available": {
      "windows": true,
      "linux": true,
      "macos": false
    }
  },
  "terminal": {
    "provider": "wezterm",
    "preference": "required",
    "default_profiles": {
      "windows": "windows-native",
      "linux": "linux-native"
    },
    "execution_profiles": [
      {
        "id": "windows-native",
        "platform": "windows",
        "environment": "native",
        "priority": 10,
        "enabled": true,
        "shell": "pwsh",
        "multiplexer": "none"
      },
      {
        "id": "linux-native",
        "platform": "linux",
        "environment": "native",
        "priority": 10,
        "enabled": true,
        "shell": "bash",
        "multiplexer": "tmux"
      },
      {
        "id": "wsl-tmux",
        "platform": "windows",
        "environment": "wsl",
        "priority": 100,
        "enabled": false,
        "shell": "bash",
        "multiplexer": "tmux",
        "distribution": "Ubuntu"
      }
    ]
  },
  "agent_switchboard": {
    "repository": "EndeavorEverlasting/AgentSwitchboard",
    "profile": "core",
    "required_agents": [
      "opencode",
      "agy",
      "goose"
    ],
    "invocation_mode": "external-versioned-contract"
  },
  "posture": {
    "install_missing_only": true,
    "preserve_existing_configuration": true,
    "automatic_authentication": false,
    "target_mutation": false,
    "tracked_runtime_evidence": false
  }
}
