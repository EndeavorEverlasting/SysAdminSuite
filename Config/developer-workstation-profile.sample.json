{
  "schema_version": "sas-developer-workstation-profile/v1",
  "schema_path": "schemas/harness/developer-workstation-profile.schema.json",
  "workspace": {
    "name": "SysAdminSuite",
    "repo_path": "dev/SysAdminSuite"
  },
  "terminal": {
    "provider": "wezterm",
    "preference": "required",
    "default_profile": "windows-native",
    "execution_profiles": [
      {
        "id": "windows-native",
        "priority": 10,
        "enabled": true,
        "shell": "pwsh",
        "multiplexer": "none"
      },
      {
        "id": "wsl-tmux",
        "priority": 100,
        "enabled": false,
        "shell": "wsl",
        "multiplexer": "tmux",
        "distribution": "Ubuntu"
      }
    ]
  },
  "agent_switchboard": {
    "repository": "EndeavorEverlasting/AgentSwitchboard",
    "profile": "core",
    "required_agents": [
      "opencode",
      "agy",
      "goose"
    ],
    "invocation_mode": "external-versioned-contract"
  },
  "posture": {
    "install_missing_only": true,
    "preserve_existing_configuration": true,
    "automatic_authentication": false,
    "target_mutation": false,
    "tracked_runtime_evidence": false
  }
}
