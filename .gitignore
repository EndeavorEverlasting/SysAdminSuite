# Runtime log output — never commit live run logs
Mapping/Logs/*
Mapping/logs/*
!Mapping/Logs/.gitkeep

# GUI worker run sessions (contain PII: usernames, paths, PIDs)
Mapping/Output/GuiRuns/
Mapping/Output/*.json

# Python
__pycache__/
*.py[cod]
*.pyo

# PowerShell transcript leftovers
*.log

# Windows artifacts
Thumbs.db
desktop.ini

# Temporary / editor
*.tmp
*.bak
*.beforeSafeProps.bak
.vscode/settings.json

# Sensitive exports (CSV results from live runs)
Mapping/Config/runs/*.txt.live
Config/exports/

# GetInfo output artifacts (generated at runtime per probe)
GetInfo/Output/

# GUI lifecycle/crash output artifacts
GUI/Output/

# Deployment tracker reconcile outputs
DeploymentTracker/Output/*
!DeploymentTracker/Output/.gitkeep

# Deployment tracker data workspace
# Keep folder structure, but do not accidentally commit live trackers or generated evidence.
data/raw/*
data/backups/*
data/experiments/*
data/outputs/*
data/updated/*
!data/raw/.gitkeep
!data/backups/.gitkeep
!data/experiments/.gitkeep
!data/outputs/.gitkeep
!data/updated/.gitkeep

# Live workbook/data artifacts require explicit private handling or sanitization.
*.xlsx
*.xlsm
*.xls
*.csv
*.tsv
*.zip
!**/.gitkeep

# Inventory outputs (generated by inventory/compare workflows)
inventory/**/installed_software_*.csv
inventory/**/installed_software_*.html
inventory/software_superset.csv
inventory/comparisons/run_*/

# Temp diagnostic / scratch scripts at repo root
_*

# Node (if any tooling gets added)
node_modules/

# Local OCR reference PDF (not tracked)
OCR/Jude's 2026 Buildout Project.pdf

# Portable build output (local only)
dist/

# Generated runtime artifacts from bash/apps scripts (timestamped logs and worker scripts)
bash/apps/output/
