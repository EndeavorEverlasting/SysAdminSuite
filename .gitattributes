# Repository text policy: normalize text to LF in Git, with checkout endings explicit only where execution requires them.
* text=auto

# Windows command launchers are stored as LF in Git and checked out as CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf

# Shell and fixture surfaces must remain LF on every platform.
*.sh text eol=lf
*.bash text eol=lf
*.fixture text eol=lf

# Parser-facing JSONL is always treated as text, but retains platform checkout behavior.
*.jsonl text

# PowerShell, data, documentation, and other text formats use Git's platform checkout behavior while remaining normalized in the repository.

# Binary artifacts must never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.msi binary
*.pcap binary
*.pcapng binary
*.evtx binary
