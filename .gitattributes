# Repository checkout policy: keep explicit EOL rules narrow and let existing platform behavior stand elsewhere.

# Windows command launchers are stored as LF in Git and checked out as CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf

# Shell and fixture surfaces must remain LF on every platform.
*.sh text eol=lf
*.bash text eol=lf
*.fixture text eol=lf

# Parser-facing JSONL is always treated as text, but retains platform checkout behavior.
*.jsonl text

# PowerShell, data, documentation, and other text formats retain the repository's existing checkout behavior.
# Canonical LF storage for changed text blobs is enforced by scripts/check-repo-text-policy.py.

# Binary artifacts must never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.msi binary
*.pcap binary
*.pcapng binary
*.evtx binary
