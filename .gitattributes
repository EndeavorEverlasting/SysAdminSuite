# Repository text policy: normalize text to LF in Git, with platform checkout endings where required.
* text=auto

# Windows operator surfaces are stored as LF in Git and checked out as CRLF on Windows.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Cross-platform harness, contracts, documentation, and configuration stay LF everywhere.
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.cs text eol=lf
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.lua text eol=lf
*.fixture text eol=lf

# Binary artifacts must never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.msi binary
*.pcap binary
*.pcapng binary
*.evtx binary
